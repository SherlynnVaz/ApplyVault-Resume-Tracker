PORT=5000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173
JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRES_IN=1d

# Database client: sqlite (default in development) or mysql
DB_CLIENT=sqlite
# SQLite database file path (relative to backend folder or absolute)
SQLITE_FILE=data/applyvault.sqlite

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=applyvault

# Resume storage: local or s3
RESUME_STORAGE=local
# Optional local upload folder override
UPLOAD_DIR=uploads/resumes

# AWS settings (used when deploying to Lambda)
AWS_REGION=us-east-1
RESUME_S3_BUCKET=
RESUME_S3_PUBLIC_BASE_URL=
SNS_TOPIC_ARN=

# Email notifications (AWS SES)
# Verify this sender identity in SES (sandbox requires verifying recipient emails too)
SES_FROM_EMAIL=
# Optional override; defaults to AWS_REGION
SES_REGION=
