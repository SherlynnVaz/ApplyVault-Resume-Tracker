AWS_REGION=us-east-1
APP_NAME=applyvault
STAGE=prod
FRONTEND_ORIGIN=https://your-frontend-domain

DB_NAME=applyvault
DB_USER=admin
DB_PASSWORD=ChangeThisStrongPassword123!
DB_INSTANCE_CLASS=db.t4g.micro
DB_ALLOCATED_STORAGE=20

JWT_SECRET=replace-this-with-a-long-random-secret

# Optional: enable candidate selection email (AWS SES)
# Must be a verified SES identity in the same region as SES
SES_FROM_EMAIL=
# Optional override; defaults to AWS_REGION
SES_REGION=

# Optional overrides
# RESUME_BUCKET=applyvault-prod-resumes-your-account-id
# DB_IDENTIFIER=applyvault-prod-db
# DB_SUBNET_GROUP=applyvault-prod-db-subnets
# DB_SG_NAME=applyvault-prod-db-sg
